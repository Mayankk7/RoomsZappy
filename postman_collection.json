              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotel_name\": \"Wings Hotel Pera\",\n  \"information_raw\": \"54 Room\",\n  \"total_rooms\": 54,\n  \"contact_raw\": \"MERVE FIDAN 0538 360 45 56\",\n  \"contact_name\": \"MERVE FIDAN\",\n  \"contact_phone\": \"0538 360 45 56\",\n  \"location_raw\": \"Asmali Mescit, Mesrutiyet Cd. No:35, 34430 Beyoglu/Istanbul\",\n  \"email\": \"merve.fidan@thewingshotel.com\",\n  \"hotel_link\": \"https://thewingshotels.com/en/pera/\",\n  \"star_rating\": 4,\n  \"property_label_raw\": null,\n  \"hotel_description\": \"The Wings group of hotels focuses on Industrial Chic design and urban luxury.\",\n  \"check_in_time\": \"14:00:00\",\n  \"check_out_time\": \"12:00:00\",\n  \"child_policy\": null,\n  \"pet_policy\": null,\n  \"smoking_policy\": null,\n  \"google_maps_link\": \"https://www.google.com/maps/search/?api=1&query=Wings+Hotel+Pera\",\n  \"room_categories\": [\n    {\n      \"room_name\": \"Standard Double And Single room\",\n      \"room_category\": \"standard\",\n      \"occupancy_code\": \"DBL-SNG\",\n      \"occupancy_type\": \"single_double\",\n      \"base_price\": 4231.00,\n      \"min_price\": 4000.00,\n      \"max_price\": 5500.00,\n      \"currency_code\": \"TRY\",\n      \"price_raw\": \"DBL-SNG 4231 TL\"\n    },\n    {\n      \"room_name\": \"Deluxe King Room\",\n      \"room_category\": \"deluxe\",\n      \"occupancy_code\": \"DBL\",\n      \"occupancy_type\": \"double\",\n      \"base_price\": 6500.00,\n      \"min_price\": 6000.00,\n      \"max_price\": 8000.00,\n      \"currency_code\": \"TRY\",\n      \"price_raw\": \"DBL 6500 TL\"\n    }\n  ],\n  \"amenities\": [\n    { \"name\": \"Wi-Fi\" },\n    { \"name\": \"Terrace Dining\" },\n    { \"name\": \"Modern AC\" },\n    { \"name\": \"Design Rooms\" }\n  ],\n  \"status\": \"active\",\n  \"manager_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/hotels/admin/create",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels", "admin", "create"]
            }
          }
        },
        {
          "name": "Admin Update Hotel",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hotel_description\": \"Updated boutique hotel description\",\n  \"google_maps_link\": \"https://maps.google.com/?q=Walton+Hotels+Galata\",\n  \"total_rooms\": 24,\n  \"check_in_time\": \"14:00:00\",\n  \"check_out_time\": \"12:00:00\",\n  \"child_policy\": \"Children above 6 years are chargeable\",\n  \"smoking_policy\": \"No smoking in rooms\",\n  \"room_categories\": [\n    {\n      \"room_name\": \"Deluxe Sea View\",\n      \"room_category\": \"deluxe\",\n      \"occupancy_code\": \"DBL-SNG\",\n      \"occupancy_type\": \"single_double\",\n      \"base_price\": 5100,\n      \"min_price\": 4800,\n      \"max_price\": 7000,\n      \"currency_code\": \"TRY\",\n      \"price_raw\": \"DBL-SNG 5100 TL\"\n    }\n  ],\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/hotels/admin/1/update",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels", "admin", "1", "update"]
            }
          }
        },
        {
          "name": "Admin Delete Hotel",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/hotels/admin/1/delete",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels", "admin", "1", "delete"]
            }
          }
        }
      ]
