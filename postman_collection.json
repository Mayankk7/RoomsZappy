{
  "info": {
    "name": "United Hotels Backend API",
    "description": "United Hotels backend API. Supports hotel CRUD with room category min/max price bounds (loss prevention), dynamic recommended pricing, authenticated and guest bookings with special_request, and payments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\",\n  \"phoneNumber\": 15551234567,\n  \"isAdmin\": false,\n  \"isManager\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/register",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('user_token', response.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/login",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const response = pm.response.json();",
                  "  pm.collectionVariables.set('admin_token', response.token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Hotels",
      "item": [
        {
          "name": "Public Hotels Full Details + Categories + Pricing",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/hotels/public?status=active&limit=50&offset=0&includeRecommendedPrices=true&refreshPrices=true",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels", "public"],
              "query": [
                { "key": "status", "value": "active" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" },
                { "key": "includeRecommendedPrices", "value": "true" },
                { "key": "refreshPrices", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "All Hotels Recommended Prices (5m Cache)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/hotels/pricing/all?status=active&refresh=true",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels", "pricing", "all"],
              "query": [
                { "key": "status", "value": "active" },
                { "key": "refresh", "value": "true" }
              ]
            }
          }
        },
        {
          "name": "Admin Hotels By Manager/User Id",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/hotels/admin?managerId=1&status=active&limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "hotels", "admin"],
              "query": [
                { "key": "managerId", "value": "1" },
                { "key": "status", "value": "active" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
