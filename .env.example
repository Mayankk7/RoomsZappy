# Backend runtime
PORT=5000
NODE_ENV=production

# Required: Postgres connection
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
PG_SSL=true

# Required: auth secret
JWT_SECRET=replace-with-a-long-random-secret

# Required for browser API calls
CORS_ORIGIN=https://your-app-name.onrender.com

# Optional: auth flow behavior
REQUIRE_EMAIL_OTP=false

# Optional: SMTP for booking confirmation emails
SMTP_USER=
SMTP_PASS=
MAIL_FROM="United Hotels <noreply@example.com>"
