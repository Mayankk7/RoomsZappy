/**
 * Environment Configuration Documentation
 * 
 * To use this API integration, set the following environment variable in your .env file:
 * 
 * VITE_API_URL=http://localhost:5000
 * 
 * The default value is 'http://localhost:5000' if not specified.
 * 
 * Example .env file:
 * ---
 * VITE_API_URL=http://localhost:5000
 * VITE_APP_NAME=United Hotels
 * VITE_APP_VERSION=1.0.0
 * ---
 * 
 * For production, update this to your production API URL:
 * VITE_API_URL=https://api.unitedhotels.com
 */

// This file documents the required environment variables
